# Auth
OCR_API_KEY=replace-me

# OCR engine (PaddleOCR 3.x)
OCR_LANGUAGE=en
OCR_USE_GPU=false
OCR_ENABLE_MKLDNN=false
OCR_USE_ANGLE_CLS=true
OCR_DET_DB_BOX_THRESH=0.3
OCR_CPU_THREADS=4
# mobile_det default (fits in 8GB on Rosetta-emulated amd64). Use server_det only
# on native amd64 with --memory=16g+ for slightly better recall on dense text.
OCR_TEXT_DETECTION_MODEL=PP-OCRv5_mobile_det
OCR_USE_DOC_ORIENTATION_CLASSIFY=true
# UVDoc unwarping default off — memory spike >8GB on Rosetta-emulated amd64.
# Enable for phone-photo curved/folded docs on native amd64 with ≥16GB RAM.
OCR_USE_DOC_UNWARPING=false
OCR_UNCLEAR_THRESHOLD=0.5

# Limits
OCR_MAX_FILE_SIZE_MB=50
OCR_MAX_PAGES=100
OCR_URL_DOWNLOAD_TIMEOUT=30
OCR_MIN_TEXT_LENGTH=50
OCR_PDF_DPI=300

# Server
LOG_LEVEL=INFO
