# Auth
OCR_API_KEY=replace-me

# OCR engine (PaddleOCR 3.x)
OCR_LANGUAGE=en
OCR_USE_GPU=false
OCR_ENABLE_MKLDNN=false
OCR_USE_ANGLE_CLS=true
OCR_DET_DB_BOX_THRESH=0.3
OCR_CPU_THREADS=4
# Pool of PaddleOCR engines per language. Pages of a PDF are OCR'd in parallel
# across these engines. Each engine uses ~200-500MB RAM and is given
# OCR_CPU_THREADS // OCR_PARALLEL_WORKERS intra-op threads, so the total CPU
# budget equals OCR_CPU_THREADS. Tune to container RAM: 2 for 2GB, 4 for 4GB+.
OCR_PARALLEL_WORKERS=4
# Run deskew + denoise + CLAHE preprocessing before OCR. Recommended for
# phone-scanned PDFs (skewed, uneven lighting). Clean pages auto-skip the
# heavy steps via an internal heuristic. Set false if inputs are already
# clean digital rasters and you want to save 100-500ms per page.
OCR_ENABLE_PREPROCESS=true
# Default OCR engine when the request does not pass `engine`.
# - paddle: PaddleOCR PP-OCRv5 mobile (current default, higher accuracy)
# - onnx:   RapidOCR PP-OCRv4 ONNX (2-4x faster on CPU)
# Per-request override via form/JSON field `engine`.
OCR_DEFAULT_ENGINE=paddle
# mobile_det default (fits in 8GB on Rosetta-emulated amd64). Use server_det only
# on native amd64 with --memory=16g+ for slightly better recall on dense text.
OCR_TEXT_DETECTION_MODEL=PP-OCRv5_mobile_det
# Recognition model. mobile_rec is ~3-4x faster on CPU than server_rec and
# uses ~300MB less RAM per engine. PaddleOCR auto-selects server_rec when
# this is unset, so always pin it explicitly. Use server_rec only when
# accuracy on small/dense text matters more than throughput.
OCR_TEXT_RECOGNITION_MODEL=PP-OCRv5_mobile_rec
OCR_USE_DOC_ORIENTATION_CLASSIFY=true
# UVDoc unwarping default off — memory spike >8GB on Rosetta-emulated amd64.
# Enable for phone-photo curved/folded docs on native amd64 with ≥16GB RAM.
OCR_USE_DOC_UNWARPING=false
OCR_UNCLEAR_THRESHOLD=0.5

# Limits
OCR_MAX_FILE_SIZE_MB=50
OCR_MAX_PAGES=100
OCR_URL_DOWNLOAD_TIMEOUT=30
OCR_MIN_TEXT_LENGTH=50
OCR_PDF_DPI=300

# Server
LOG_LEVEL=INFO
